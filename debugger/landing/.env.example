# Landing page environment variables — copy to .env and fill in values

# URL of the backend API (used for OAuth redirects and email auth requests)
# Local:       http://localhost:8000
# Production:  https://your-api.up.railway.app
VITE_API_BASE_URL=http://localhost:8000

# URL of the main tool frontend (used for post-login redirects)
# Local:       http://localhost:5173
# Production:  https://your-tool.vercel.app
VITE_TOOL_URL=http://localhost:5173

# OAuth client IDs (public — safe to expose in frontend)
VITE_GITHUB_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=
