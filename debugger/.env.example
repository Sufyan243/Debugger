# Backend — copy to debugger/.env and fill in values
DATABASE_URL=postgresql+asyncpg://debugger:debugger@postgres:5432/debugger

JWT_SECRET_KEY=change-me-in-production

ALLOWED_ORIGINS=http://localhost:5173

ENV=development

# URL the browser uses to reach the frontend (used in OAuth final redirect)
FRONTEND_URL=http://localhost:5173

# URL used to build OAuth callback URIs sent to GitHub/Google.
# Must match the callback URL registered in your OAuth app settings.
#
# Local Docker (default):     BACKEND_URL=http://localhost:8000
#   Register callback as:     http://localhost:8000/api/v1/auth/github/callback
#
# Local non-Docker (direct):  BACKEND_URL=http://localhost:8000
#   Same as above.
#
# Production (Railway):       BACKEND_URL=https://your-service.up.railway.app
#   Register callback as:     https://your-service.up.railway.app/api/v1/auth/github/callback
#
BACKEND_URL=http://localhost:8000

# GitHub OAuth — create app at https://github.com/settings/developers
# Authorization callback URL: <BACKEND_URL>/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create app at https://console.cloud.google.com
# Authorized redirect URI: <BACKEND_URL>/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

SANDBOX_IMAGE=python:3.11-slim
# Execution timeout per sandbox run in seconds.
# Set to 5 to handle common beginner patterns like for i in range(1_000_000).
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEM_LIMIT=64m
SANDBOX_CPU_QUOTA=500000000
MAX_CODE_LENGTH=10000

# Email / SMTP — used for email verification
# Example: smtp.gmail.com (Gmail), smtp.sendgrid.net (SendGrid)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
VERIFICATION_TOKEN_EXPIRE_MINUTES=30
# Set to true in local dev to skip SMTP and log the verification link instead.
# Never set this in production.
DEV_SKIP_EMAIL=false
