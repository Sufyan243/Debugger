# Copy this file to .env and fill in every CHANGE_ME value before starting.
# Generate secrets with: openssl rand -hex 32

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://debugger:debugger@postgres:5432/debugger

# ── Auth ────────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME

# ── CORS ────────────────────────────────────────────────────────────────────
# Production: set to your exact frontend URL only, no trailing slash.
# Dev: http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

ENV=development

# ── Frontend Build ──────────────────────────────────────────────────────────
# Baked into the frontend bundle at build time — must be the public API URL.
VITE_API_BASE_URL=https://api.terradebugger.me

# ── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Must match the callback URL registered in your OAuth app settings.
BACKEND_URL=http://localhost:8000

# ── OAuth — GitHub ──────────────────────────────────────────────────────────
# Create app at https://github.com/settings/developers
# Callback URL: <BACKEND_URL>/api/v1/auth/github/callback
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME

# ── OAuth — Google ──────────────────────────────────────────────────────────
# Create app at https://console.cloud.google.com
# Redirect URI: <BACKEND_URL>/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# ── Sandbox ─────────────────────────────────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEM_LIMIT=64m
SANDBOX_CPU_QUOTA=500000000
MAX_CODE_LENGTH=10000
# Path to the isolated Docker daemon (set by docker-compose; do not change).
SANDBOX_DOCKER_URL=tcp://docker-sandbox:2376
# Mutual TLS certs — mounted from the sandbox-certs volumes by docker-compose.
SANDBOX_DOCKER_TLS_CA=/certs/ca/ca.pem
SANDBOX_DOCKER_TLS_CERT=/certs/client/cert.pem
SANDBOX_DOCKER_TLS_KEY=/certs/client/key.pem
# Seccomp profile path inside the backend container (copied by Dockerfile).
SANDBOX_SECCOMP_PROFILE=/app/seccomp/sandbox-deny-spawn.json

# ── Redis ───────────────────────────────────────────────────────────────────
# Production: include the password — redis://:PASSWORD@redis:6379/0
REDIS_URL=redis://localhost:6379/0
# REQUIRED in production — generate with: openssl rand -hex 32
REDIS_PASSWORD=CHANGE_ME

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASSWORD=CHANGE_ME
EMAIL_FROM=CHANGE_ME
VERIFICATION_TOKEN_EXPIRE_MINUTES=30
# Set true in local dev only to skip SMTP and log the link instead.
DEV_SKIP_EMAIL=false
