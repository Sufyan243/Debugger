# Backend — copy to debugger/.env and fill in values
# For Railway/Render + Supabase, use the Supabase connection string with asyncpg driver:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://debugger:debugger@postgres:5432/debugger

JWT_SECRET_KEY=change-me-in-production

# Comma-separated list of allowed CORS origins
# Production example: ALLOWED_ORIGINS=https://yourdomain.me,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173

# Set to "production" on Railway/Render to enable safety checks
ENV=development

SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=3
SANDBOX_MEM_LIMIT=64m
SANDBOX_CPU_QUOTA=500000000
MAX_CODE_LENGTH=10000
