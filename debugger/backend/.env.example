# Backend environment variables — copy to .env and fill in real values.
# The server will refuse to start if JWT_SECRET_KEY is left as the default.

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/debugger

# ── Security ────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_A_STRONG_SECRET

# ── Environment ─────────────────────────────────────────────────────────────
# Set to "production" in prod — controls cookie Secure flag, log level, docs visibility
ENV=production

# ── URLs ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://REPLACE_WITH_FRONTEND_URL
BACKEND_URL=https://REPLACE_WITH_BACKEND_URL
ALLOWED_ORIGINS=https://REPLACE_WITH_FRONTEND_URL

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── OAuth ───────────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
VERIFICATION_TOKEN_EXPIRE_MINUTES=30

# ── Sandbox ──────────────────────────────────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT_SECONDS=5
SANDBOX_MEM_LIMIT=64m
SANDBOX_CPU_QUOTA=500000000
SANDBOX_SECCOMP_PROFILE=/app/seccomp/sandbox-deny-spawn.json
MAX_CODE_LENGTH=10000

# ── Dev helpers (never enable in production) ─────────────────────────────────
DEV_SKIP_EMAIL=false
